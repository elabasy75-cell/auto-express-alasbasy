  const handleDiagSearch = (code) => {
    const formattedCode = code.trim().toUpperCase();
    setDiagSearch(formattedCode);
    const match = diagCodes.find(c => c.code === formattedCode);
    setMatchedDiag(match || null);
  };

  // Quick Action: Add new custom diagnostic code
  const [newDiagCode, setNewDiagCode] = useState('');
