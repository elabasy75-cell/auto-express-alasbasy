  const [newCatType, setNewCatType] = useState('spare');
  const [newCatPrice, setNewCatPrice] = useState('');
  const [newCatCategory, setNewCatCategory] = useState('أخرى');
  const [newCatStock, setNewCatStock] = useState(10);
  const [isCatAddOpen, setIsCatAddOpen] = useState(false);

