    if (!newDiagCode || !newDiagTitle) return;
    const item = {
      code: newDiagCode.trim().toUpperCase(),
      title: newDiagTitle,
      system: 'عام ومتقدم',
      gravity: 'medium',
      description: newDiagDesc,
      causes: newDiagCauses,
      solution: newDiagSol
