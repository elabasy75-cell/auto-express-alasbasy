    e.preventDefault();
    if (!newCatName || !newCatPrice) return;
    const newItem = {
      id: `C-${Date.now()}`,
      name: newCatName,
      type: newCatType,
      price: Number(newCatPrice),
      category: newCatCategory,
      stock: newCatType === 'spare' ? Number(newCatStock) : 999
    };
    setCatalog([newItem, ...catalog]);
    setNewCatName('');
    setNewCatPrice('');
    setNewCatStock(10);
    setIsCatAddOpen(false);
  };

  // Delete Repair Job
  const handleDeleteRepair = (id) => {
    if(window.confirm('هل أنت متأكد من حذف أمر الإصلاح هذا نهائياً؟')) {
      setRepairs(prev => prev.filter(r => r.id !== id));
    }
  };

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans selection:bg-yellow-500 selection:text-slate-900" dir="rtl">
      
      {/* Slogan Banner Top */}
      {alertSlogan && (
        <div className="bg-gradient-to-r from-yellow-500 via-amber-400 to-yellow-600 text-slate-950 px-4 py-2 flex items-center justify-between text-xs sm:text-sm font-bold shadow-md relative overflow-hidden">
