  const [newDiagDesc, setNewDiagDesc] = useState('');
  const [newDiagCauses, setNewDiagCauses] = useState('');
  const [newDiagSol, setNewDiagSol] = useState('');
  const [isDiagAddOpen, setIsDiagAddOpen] = useState(false);

