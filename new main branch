  const [activeTab, setActiveTab] = useState('dashboard');
  const [sidebarOpen, setSidebarOpen] = useState(false);

  // States for dynamic data management
  const [repairs, setRepairs] = useState(() => {
    const saved = localStorage.getItem('auto_express_repairs');
    return saved ? JSON.parse(saved) : INITIAL_REPAIRS;
  });

  const [catalog, setCatalog] = useState(() => {
    const saved = localStorage.getItem('auto_express_catalog');
    return saved ? JSON.parse(saved) : INITIAL_CATALOG;
  });

  const [diagCodes, setDiagCodes] = useState(INITIAL_DIAG_CODES);

  // Sync with LocalStorage
  useEffect(() => {
    localStorage.setItem('auto_express_repairs', JSON.stringify(repairs));
  }, [repairs]);

