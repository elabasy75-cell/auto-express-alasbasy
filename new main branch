  const [isBillModalOpen, setIsBillModalOpen] = useState(false);
  const [selectedRepairForBill, setSelectedRepairForBill] = useState(null);
  const [isInspectionModalOpen, setIsInspectionModalOpen] = useState(false);
  const [selectedRepairForInspection, setSelectedRepairForInspection] = useState(null);
  
  // States for diagnostic lookup
  const [diagSearch, setDiagSearch] = useState('');
  const [matchedDiag, setMatchedDiag] = useState(null);

  // States for New Repair Intake Form
  const [newPlate, setNewPlate] = useState('');
  const [newModel, setNewModel] = useState('');
  const [newCustName, setNewCustName] = useState('');
  const [newCustPhone, setNewCustPhone] = useState('');
  const [newIssue, setNewIssue] = useState('');
  const [newMechanic, setNewMechanic] = useState('غير محدد');

  // Fast Bill Editing state
  const [billItemsTemp, setBillItemsTemp] = useState([]);
  const [billDiscountTemp, setBillDiscountTemp] = useState(0);

  // Inspection Temp State
  const [inspectEngine, setInspectEngine] = useState('pass');
  const [inspectBrakes, setInspectBrakes] = useState('pass');
  const [inspectSuspension, setInspectSuspension] = useState('pass');
  const [inspectFluids, setInspectFluids] = useState('pass');
  const [inspectElectronics, setInspectElectronics] = useState('pass');
  const [inspectNotes, setInspectNotes] = useState('');

  // Slogan notification/ticker
  const [alertSlogan, setAlertSlogan] = useState(true);

  // Quick stats calculations
  const stats = useMemo(() => {
    const totalActive = repairs.filter(r => r.status !== 'ready').length;
    const completedToday = repairs.filter(r => r.status === 'ready').length;
    const pendingCount = repairs.filter(r => r.status === 'pending').length;
    const totalRevenue = repairs.reduce((acc, r) => {
      const subtotal = r.billItems.reduce((s, item) => s + (item.price * (item.qty || 1)), 0);
      return acc + (subtotal - (r.discount || 0));
    }, 0);

    return { totalActive, completedToday, pendingCount, totalRevenue };
  }, [repairs]);

  // Handle Adding a New Repair
  const handleCreateRepair = (e) => {
    e.preventDefault();
    if (!newPlate || !newModel || !newCustName) return;

    const newJob = {
      id: `R-${100 + repairs.length + 1}`,
      plateNumber: newPlate,
      carModel: newModel,
      customerName: newCustName,
      customerPhone: newCustPhone || 'بدون رقم هاتف',
      status: 'pending',
      issue: newIssue,
      mechanic: newMechanic,
      intakeDate: new Date().toISOString().split('T')[0],
      expectedDelivery: new Date(Date.now() + 86400000).toISOString().split('T')[0], // غدا بشكل افتراضي
      billItems: [],
      discount: 0,
      inspectionResult: null
    };

    setRepairs([newJob, ...repairs]);
    setIsNewRepairModalOpen(false);
    // Clear state
    setNewPlate('');
    setNewModel('');
    setNewCustName('');
    setNewCustPhone('');
    setNewIssue('');
    setNewMechanic('غير محدد');
  };

  // Handle changing progress status
  const handleStatusChange = (repairId, newStatus) => {
    setRepairs(prev => prev.map(r => r.id === repairId ? { ...r, status: newStatus } : r));
  };

  // Open Fast Bill Editor
  const openBillEditor = (repair) => {
    setSelectedRepairForBill(repair);
    setBillItemsTemp([...repair.billItems]);
    setBillDiscountTemp(repair.discount || 0);
    setIsBillModalOpen(true);
  };

  // Save Fast Bill
  const saveBill = () => {
    setRepairs(prev => prev.map(r => {
      if (r.id === selectedRepairForBill.id) {
        return {
          ...r,
          billItems: billItemsTemp,
          discount: Number(billDiscountTemp)
        };
      }
      return r;
    }));
    setIsBillModalOpen(false);
  };

  // Add Item to Bill Temp
  const addItemToBillTemp = (catalogItem) => {
    const exists = billItemsTemp.find(i => i.name === catalogItem.name);
    if (exists) {
      setBillItemsTemp(prev => prev.map(i => i.name === catalogItem.name ? { ...i, qty: (i.qty || 1) + 1 } : i));
    } else {
      setBillItemsTemp(prev => [...prev, { name: catalogItem.name, price: catalogItem.price, qty: 1 }]);
    }
  };

  const removeBillItemTemp = (index) => {
    setBillItemsTemp(prev => prev.filter((_, i) => i !== index));
  };

  // Open Inspection Editor
  const openInspectionEditor = (repair) => {
    setSelectedRepairForInspection(repair);
    if (repair.inspectionResult) {
      setInspectEngine(repair.inspectionResult.engine);
      setInspectBrakes(repair.inspectionResult.brakes);
      setInspectSuspension(repair.inspectionResult.suspension);
      setInspectFluids(repair.inspectionResult.fluids);
      setInspectElectronics(repair.inspectionResult.electronics);
      setInspectNotes(repair.inspectionResult.notes);
    } else {
      setInspectEngine('pass');
      setInspectBrakes('pass');
      setInspectSuspension('pass');
      setInspectFluids('pass');
      setInspectElectronics('pass');
      setInspectNotes('');
    }
    setIsInspectionModalOpen(true);
  };

  // Save Inspection Result
  const saveInspection = () => {
    setRepairs(prev => prev.map(r => {
      if (r.id === selectedRepairForInspection.id) {
        return {
          ...r,
          inspectionResult: {
            engine: inspectEngine,
            brakes: inspectBrakes,
            suspension: inspectSuspension,
            fluids: inspectFluids,
            electronics: inspectElectronics,
            notes: inspectNotes
          }
        };
      }
      return r;
    }));
    setIsInspectionModalOpen(false);
  };

