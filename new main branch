  const total = subtotal - (repair.discount || 0);

  return (
    <div className="bg-slate-950 p-4 rounded-xl border border-slate-850 hover:border-slate-700 transition space-y-3 relative overflow-hidden group">
      
      {/* Delete quick handler */}
      <button 
        onClick={() => onDelete(repair.id)}
        className="absolute top-2 left-2 text-slate-600 hover:text-red-400 opacity-0 group-hover:opacity-100 transition duration-200"
        title="حذف أمر الصيانة"
      >
        <Trash2 size={12} />
      </button>

      {/* Plate and Car Info */}
      <div className="space-y-1">
        <div className="flex items-center gap-1.5 flex-wrap">
          <span className="bg-slate-900 text-yellow-400 border border-yellow-500/20 text-[11px] font-black px-2 py-0.5 rounded tracking-wide">
            {repair.plateNumber}
          </span>
          <span className="text-[10px] text-slate-500 font-bold">{repair.id}</span>
        </div>
        <h4 className="font-bold text-white text-sm mt-1">{repair.carModel}</h4>
      </div>

      {/* Customer Info */}
      <div className="space-y-0.5 text-xs text-slate-400">
        <p className="flex items-center gap-1">
          <User size={11} className="text-slate-500" />
          <span className="font-medium text-slate-300 line-clamp-1">{repair.customerName}</span>
        </p>
        <p className="flex items-center gap-1 font-mono text-[10px]">
          <Phone size={11} className="text-slate-500" />
          <span>{repair.customerPhone}</span>
        </p>
      </div>

      {/* Issue details block */}
      <div className="bg-slate-900/50 p-2 rounded text-xs border border-slate-850/40 text-yellow-300 font-semibold line-clamp-2">
        🛠️ {repair.issue}
      </div>

      {/* Financials & Status Changer */}
      <div className="pt-2 border-t border-slate-850/60 flex items-center justify-between text-xs gap-2">
        <div className="flex flex-col">
          <span className="text-[10px] text-slate-500">حساب الفاتورة</span>
          <span className="font-mono font-bold text-green-400 text-xs">{total.toLocaleString()} ج.م</span>
        </div>

        {/* Rapid Stage Transition Select Box */}
        <div className="flex items-center gap-1">
          <select 
            value={repair.status}
            onChange={(e) => onStatusChange(repair.id, e.target.value)}
            className="bg-slate-900 border border-slate-800 text-[10px] font-bold rounded-lg px-2 py-1 text-slate-300 outline-none focus:border-yellow-500"
          >
            <option value="pending">بانتظار الفحص</option>
            <option value="in-progress">قيد العمل</option>
            <option value="testing">تحت التجربة</option>
            <option value="ready">جاهزة للتسليم</option>
          </select>
        </div>
      </div>

      {/* Quick Tool Links inside Card */}
      <div className="grid grid-cols-2 gap-1.5 pt-1.5">
        <button 
          onClick={() => openInspect(repair)}
          className={`px-2 py-1.5 rounded text-[10px] font-black transition flex items-center justify-center gap-1 ${
            repair.inspectionResult ? 'bg-green-500/15 text-green-400' : 'bg-slate-900 hover:bg-slate-850 text-slate-300'
          }`}
        >
          <ClipboardCheck size={11} />
          <span>{repair.inspectionResult ? 'تم الفحص ✓' : 'افحص الآن'}</span>
        </button>
        <button 
          onClick={() => openBill(repair)}
          className="bg-yellow-500/10 hover:bg-yellow-500/20 text-yellow-500 border border-yellow-500/20 px-2 py-1.5 rounded text-[10px] font-black transition flex items-center justify-center gap-1"
        >
          <DollarSign size={11} />
          <span>الفاتورة والدفع</span>
        </button>
      </div>

    </div>
  );
}
